---
import { getCopy, topics, typedResources, type Language } from "../lib/content";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const copy = getCopy(lang);
---

<section class="coverage-board" aria-label={copy.topics}>
  {topics
    .map((topic) => {
      const related = typedResources.filter((resource) => resource.topics.includes(topic.id));
      const official = related.filter((resource) => resource.englishStatus === "official").length;
      return {
        topic,
        related,
        official
      };
    })
    .sort((a, b) => b.related.length - a.related.length || a.topic.label[lang].localeCompare(b.topic.label[lang], lang === "zh" ? "zh-CN" : "en"))
    .map(({ topic, related, official }) => (
      <a class="coverage-item" href={`/${lang}/topics/${topic.id}/`}>
        <strong>{topic.label[lang]}</strong>
        <span>{related.length} {copy.records}</span>
        <small>{official} {copy.officialEnglish}</small>
      </a>
    ))}
</section>
