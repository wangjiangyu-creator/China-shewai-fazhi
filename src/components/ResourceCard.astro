---
import {
  formatDate,
  getCategory,
  getCopy,
  getKind,
  getTopic,
  resourceSearchText,
  languagePath,
  type Language,
  type Resource
} from "../lib/content";

interface Props {
  resource: Resource;
  lang: Language;
}

const { resource, lang } = Astro.props;
const copy = getCopy(lang);
const category = getCategory(resource.category);
const kind = getKind(resource.kind);
const statusLabel =
  resource.englishStatus === "official"
    ? copy.officialEnglish
    : resource.englishStatus === "summary-only"
      ? copy.englishSummaryOnly
      : copy.noOfficialEnglish;
const hasSharedSource = resource.officialEnglishUrl && resource.officialEnglishUrl === resource.officialChineseUrl;
---

<article
  class="resource-card"
  data-resource-card
  data-category={resource.category}
  data-kind={resource.kind}
  data-topics={resource.topics.join(" ")}
  data-year={resource.date.slice(0, 4)}
  data-authority={resource.authority[lang]}
  data-english-status={resource.englishStatus}
  data-scholarship-type={resource.scholarshipType ?? ""}
  data-source-language={resource.sourceLanguage ?? ""}
  data-publication-type={resource.publicationType ?? ""}
  data-search={resourceSearchText(resource).toLowerCase()}
>
  <div class="card-topline">
    <a class="category-pill" href={languagePath(lang, `/categories/${resource.category}/`)}>
      {category.label[lang]}
    </a>
    <span class="kind-pill">{kind.label[lang]}</span>
    <span class:list={["status-pill", resource.englishStatus]}>{statusLabel}</span>
  </div>
  <h3>
    <a href={languagePath(lang, `/resources/${resource.slug}/`)}>{resource.title[lang]}</a>
  </h3>
  <p>{resource.summary[lang]}</p>
  <dl class="meta-grid">
      <div>
        <dt>{copy.source}</dt>
        <dd>{resource.authority[lang]}</dd>
      </div>
      {resource.authors && (
        <div>
          <dt>{copy.author}</dt>
          <dd>{resource.authors[lang]}</dd>
        </div>
      )}
      <div>
        <dt>{copy.date}</dt>
        <dd>{formatDate(resource.date, lang)}</dd>
      </div>
  </dl>
  <div class="tag-row">
    {resource.topics.slice(0, 3).map((topicId) => (
      <a href={languagePath(lang, `/topics/${topicId}/`)}>{getTopic(topicId).label[lang]}</a>
    ))}
  </div>
  <div class="card-actions">
    <a href={resource.officialChineseUrl} target="_blank" rel="noreferrer">
      {hasSharedSource ? copy.sourceLink : copy.officialCn}
    </a>
    {resource.officialEnglishUrl && !hasSharedSource ? (
      <a href={resource.officialEnglishUrl} target="_blank" rel="noreferrer">{copy.officialEn}</a>
    ) : (
      !hasSharedSource && <span>{copy.englishSummaryOnly}</span>
    )}
  </div>
</article>
