---
import SearchPanel from "../../../components/SearchPanel.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  getCopy,
  getTopic,
  getKind,
  languagePath,
  topics,
  typedResources,
  formatDate,
  type Language
} from "../../../lib/content";

export function getStaticPaths() {
  return ["zh", "en"].flatMap((lang) => topics.map((topic) => ({ params: { lang, topic: topic.id } })));
}

const lang = Astro.params.lang as Language;
const topicId = Astro.params.topic as string;
const copy = getCopy(lang);
const topic = getTopic(topicId);
const resources = typedResources.filter((resource) => resource.topics.includes(topicId));

const sortedYears = resources.map((resource) => resource.date.slice(0, 4)).sort((a, b) => b.localeCompare(a));
const yearRange = sortedYears.length ? `${sortedYears[sortedYears.length - 1]} - ${sortedYears[0]}` : copy.noTopicRecords;
const officialEnglishCount = resources.filter((resource) => resource.englishStatus === "official").length;

const kindStats = Object.entries(
  resources.reduce(
    (acc, resource) => {
      acc[resource.kind] = (acc[resource.kind] ?? 0) + 1;
      return acc;
    },
    {} as Record<string, number>
  )
).map(([kindId, count]) => ({
  kind: getKind(kindId),
  count
}));

kindStats.sort((a, b) => b.count - a.count || a.kind.label[lang].localeCompare(b.kind.label[lang], lang === "zh" ? "zh-CN" : "en"));

const authorityStats = Object.entries(
  resources.reduce(
    (acc, resource) => {
      const authority = resource.authority[lang];
      acc[authority] = (acc[authority] ?? 0) + 1;
      return acc;
    },
    {} as Record<string, number>
  )
).map(([authority, count]) => ({ authority, count }));

authorityStats.sort((a, b) => b.count - a.count || a.authority.localeCompare(b.authority, lang === "zh" ? "zh-CN" : "en"));

const latestInTopic = [...resources].sort((a, b) => b.date.localeCompare(a.date)).slice(0, 6);

const relatedTopicRows = topics
  .filter((item) => item.id !== topicId)
  .map((otherTopic) => {
    const overlap = resources.filter((resource) => resource.topics.includes(otherTopic.id)).length;
    return { topic: otherTopic, overlap };
  })
  .filter((item) => item.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || a.topic.label[lang].localeCompare(b.topic.label[lang], lang === "zh" ? "zh-CN" : "en"))
  .slice(0, 4);
---

<BaseLayout lang={lang} title={topic.label[lang]} active="topics" alternatePath={`/topics/${topicId}/`}>
  <section class="page-band">
    <div class="page-band-inner">
      <p class="eyebrow">{copy.topics}</p>
      <h1>{topic.label[lang]}</h1>
      <p class="section-lead">{topic.description[lang]}</p>
    </div>
  </section>
  <section class="section">
    <div class="section-header">
      <div>
        <h2>{copy.topicCoverage}</h2>
      </div>
    </div>
    {resources.length > 0 && (
      <div class="topic-metrics">
        <article class="detail-panel">
          <h3>{copy.records}</h3>
          <p>{resources.length} {copy.records}</p>
        </article>
        <article class="detail-panel">
          <h3>{copy.officialEnglish}</h3>
          <p>{officialEnglishCount} / {resources.length}</p>
        </article>
        <article class="detail-panel">
          <h3>{copy.recordsByYearRange}</h3>
          <p>{yearRange}</p>
        </article>
        <article class="detail-panel">
          <h3>{copy.topAuthorities}</h3>
          <p>
            {authorityStats.length > 0
              ? `${authorityStats[0].authority} · ${authorityStats[0].count} ${copy.records}`
              : copy.noTopicRecords}
          </p>
        </article>
      </div>
    )}
    {resources.length === 0 && <p class="section-lead">{copy.noTopicRecords}</p>}
  </section>
  {resources.length > 0 && (
    <>
      <section class="section">
        <h2>{copy.resourceTypeBreakdown}</h2>
        <div class="tool-grid">
          {kindStats.map((item) => (
            <article class="tool-card">
              <h3>{item.kind.label[lang]}</h3>
              <p>{item.count} {copy.records}</p>
            </article>
          ))}
        </div>
      </section>
      <section class="section">
        <h2>{copy.authorityTop}</h2>
        <div class="tool-grid">
          {authorityStats.slice(0, 6).map((item) => (
            <article class="tool-card">
              <h3>
                <a
                  href={languagePath(lang, `/resources/?topic=${encodeURIComponent(topicId)}&authority=${encodeURIComponent(item.authority)}`)}
                >
                  {item.authority}
                </a>
              </h3>
              <p>{item.count} {copy.records}</p>
            </article>
          ))}
        </div>
      </section>
      <section class="section">
        <h2>{copy.latestInTopic}</h2>
        <div class="tool-grid">
          {latestInTopic.map((resource) => (
            <article class="tool-card">
              <h3>
                <a href={languagePath(lang, `/resources/${resource.slug}/`)}>{resource.title[lang]}</a>
              </h3>
              <p>{resource.summary[lang]}</p>
              <p class="meta-line">
                {resource.authority[lang]} · {formatDate(resource.date, lang)}
              </p>
            </article>
          ))}
        </div>
      </section>
      {relatedTopicRows.length > 0 && (
        <section class="section">
          <h2>{copy.relatedTopics}</h2>
          <div class="tool-grid">
            {relatedTopicRows.map((item) => (
              <article class="tool-card">
                <h3>
                  <a href={languagePath(lang, `/topics/${item.topic.id}/`)}>{item.topic.label[lang]}</a>
                </h3>
                <p>{item.overlap} {copy.records}</p>
              </article>
            ))}
          </div>
        </section>
      )}
    </>
  )}
  <section class="section">
    <h2>{copy.featured}</h2>
    <p class="section-lead">
      {lang === "zh"
        ? "检索区可用于在本专题内快速筛选和定位目标资料。"
        : "Use the search panel below to quickly filter and locate records in this topic."}
    </p>
    <SearchPanel lang={lang} resources={resources} compact showAuthorityFilter />
  </section>
</BaseLayout>
