---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCopy, languagePath, tools, type Language } from "../../../lib/content";

export function getStaticPaths() {
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Language;
const copy = getCopy(lang);
---

<BaseLayout lang={lang} title={copy.navTools} active="tools" alternatePath="/tools/">
  <section class="page-band">
    <div class="page-band-inner">
      <p class="eyebrow">{copy.navTools}</p>
      <h1>{copy.tools}</h1>
      <p class="section-lead">
        {lang === "zh"
          ? "用于持续维护资料库的时间线、关键词、法律工具箱、官方来源和项目成果入口。"
          : "Timeline, keywords, toolbox, official source map, and project outputs for maintaining the research portal."}
      </p>
    </div>
  </section>
  <section class="section">
    <div class="tool-grid">
      {tools.map((tool) => (
        <article class="tool-card">
          <h3>{tool.label[lang]}</h3>
          <p>{tool.description[lang]}</p>
          <a class="hero-link" href={languagePath(lang, `/tools/${tool.id}/`)}>{lang === "zh" ? "打开" : "Open"}</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
