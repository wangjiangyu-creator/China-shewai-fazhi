---
import SearchPanel from "../../../components/SearchPanel.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCopy, typedResources, type Language } from "../../../lib/content";

export function getStaticPaths() {
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Language;
const copy = getCopy(lang);
const libraryResources = typedResources.filter((resource) => resource.category !== "scholarship");
---

<BaseLayout lang={lang} title={copy.navResources} active="resources" alternatePath="/resources/">
  <section class="page-band">
    <div class="page-band-inner">
      <p class="eyebrow">{copy.navResources}</p>
      <h1>{copy.categories}</h1>
      <p class="section-lead">{copy.intro}</p>
    </div>
  </section>
  <section class="section">
    <SearchPanel lang={lang} resources={libraryResources} compact showAuthorityFilter />
  </section>
</BaseLayout>
