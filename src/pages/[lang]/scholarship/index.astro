---
import ResourceCard from "../../../components/ResourceCard.astro";
import SearchPanel from "../../../components/SearchPanel.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCopy, typedResources, type Language, type Resource } from "../../../lib/content";

export function getStaticPaths() {
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Language;
const copy = getCopy(lang);
const scholarshipResources = (typedResources as Resource[])
  .filter((resource) => resource.category === "scholarship")
  .sort((a, b) => b.date.localeCompare(a.date));
const foundational = scholarshipResources.filter((resource) => resource.scholarshipType === "foundational");
const specialized = scholarshipResources.filter((resource) => resource.scholarshipType === "specialized");
const latest = scholarshipResources.slice(0, 6);
const chineseSources = scholarshipResources.filter((resource) => ["zh", "bilingual"].includes(resource.sourceLanguage ?? ""));
const englishSources = scholarshipResources.filter((resource) => ["en", "bilingual"].includes(resource.sourceLanguage ?? ""));
const officialEnglish = scholarshipResources.filter((resource) => resource.officialEnglishUrl);
const formalPublicationRecords = scholarshipResources.filter((resource) => ["journal", "book"].includes(resource.publicationType ?? ""));
---

<BaseLayout
  lang={lang}
  title={copy.navScholarship}
  description={copy.scholarshipIntro}
  active="scholarship"
  alternatePath="/scholarship/"
>
  <section class="page-band">
    <div class="page-band-inner">
      <p class="eyebrow">{copy.navScholarship}</p>
      <h1>{copy.scholarship}</h1>
      <p class="section-lead">{copy.scholarshipIntro}</p>
      <div class="stat-grid page-stat-grid" aria-label={lang === "zh" ? "学术文献统计" : "Scholarship statistics"}>
        <div class="stat">
          <strong>{scholarshipResources.length}</strong>
          <span>{copy.records}</span>
        </div>
        <div class="stat">
          <strong>{formalPublicationRecords.length}</strong>
          <span>{lang === "zh" ? "期刊/图书" : "Journals / books"}</span>
        </div>
        <div class="stat">
          <strong>{chineseSources.length}</strong>
          <span>{lang === "zh" ? "中文来源" : "Chinese sources"}</span>
        </div>
        <div class="stat">
          <strong>{englishSources.length}</strong>
          <span>{lang === "zh" ? "英文来源" : "English sources"}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <h2>{lang === "zh" ? "文献导览" : "Scholarship guide"}</h2>
        <p class="section-lead">
          {lang === "zh"
            ? "先按研究功能分为基础理论与专门问题，再通过检索框按关键词、专题、年份和英文状态筛选。"
            : "Start with foundational theory or specialized issues, then filter by keyword, topic, year, and English-source status."}
        </p>
      </div>
      <a class="hero-link" href="#scholarship-search">{lang === "zh" ? "进入检索" : "Search records"}</a>
    </div>
    <div class="source-list">
      <article class="source-row scholarship-track">
        <div>
          <h3>{copy.foundationalScholarship}</h3>
          <p>
            {lang === "zh"
              ? "概念源流、体系定位、法治话语、对外关系法治化和国际法秩序研究。"
              : "Conceptual history, system positioning, legal discourse, legalization of foreign relations, and international legal order."}
          </p>
        </div>
        <div class="source-stats">
          <span>{foundational.length} {copy.records}</span>
        </div>
        <div class="source-links">
          <a href="#scholarship-search">{lang === "zh" ? "检索基础理论" : "Search theory"}</a>
        </div>
      </article>
      <article class="source-row scholarship-track">
        <div>
          <h3>{copy.specializedScholarship}</h3>
          <p>
            {lang === "zh"
              ? "制裁与反制裁、涉外纠纷解决、数据跨境、企业合规、海外利益保护和人才培养。"
              : "Sanctions and countermeasures, dispute resolution, cross-border data, compliance, overseas interests, and talent development."}
          </p>
        </div>
        <div class="source-stats">
          <span>{specialized.length} {copy.records}</span>
        </div>
        <div class="source-links">
          <a href="#scholarship-search">{lang === "zh" ? "检索专门问题" : "Search issues"}</a>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <h2>{lang === "zh" ? "近期文献" : "Recent scholarship"}</h2>
        <p class="section-lead">
          {lang === "zh"
            ? "优先展示新近入库的正式刊物、机构研究和智库分析。"
            : "Recently added journal articles, institutional research, and think-tank analysis."}
        </p>
      </div>
      <span class="hero-link">{officialEnglish.length} {copy.officialEnglish}</span>
    </div>
    <div class="resource-grid">
      {latest.map((resource) => <ResourceCard resource={resource} lang={lang} />)}
    </div>
  </section>

  <section class="section" id="scholarship-search">
    <SearchPanel
      lang={lang}
      resources={scholarshipResources}
      compact
      showScholarshipFilters
      showAuthorityFilter
    />
  </section>
</BaseLayout>
