---
import SearchPanel from "../../components/SearchPanel.astro";
import ResourceCard from "../../components/ResourceCard.astro";
import CoverageBoard from "../../components/CoverageBoard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  categories,
  getCopy,
  latestResources,
  languagePath,
  topics,
  tools,
  typedResources,
  type Language
} from "../../lib/content";

export function getStaticPaths() {
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Language;
const copy = getCopy(lang);
const latest = latestResources(6);
const libraryCategories = categories.filter((category) => category.id !== "scholarship");
---

<BaseLayout lang={lang} title={copy.navHome} active="home" alternatePath="/">
  <section class="hero">
    <div class="hero-inner">
      <div>
        <p class="eyebrow">{copy.eyebrow}</p>
        <h1>{copy.headline}</h1>
        <p>{copy.intro}</p>
        <div class="hero-actions">
          <a class="hero-link primary" href="#search">{lang === "zh" ? "进入资料库" : "Open library"}</a>
          <a class="hero-link" href={languagePath(lang, "/scholarship/")}>{copy.navScholarship}</a>
          <a class="hero-link" href={languagePath(lang, "/topics/")}>{copy.navTopics}</a>
        </div>
      </div>
      <aside class="hero-card" aria-label="Portal statistics">
        <div class="stat-grid">
          <div class="stat">
            <strong>{typedResources.length}</strong>
            <span>{copy.records}</span>
          </div>
          <div class="stat">
            <strong>{libraryCategories.length}</strong>
            <span>{copy.categories}</span>
          </div>
          <div class="stat">
            <strong>{topics.length}</strong>
            <span>{copy.topics}</span>
          </div>
          <div class="stat">
            <strong>{typedResources.filter((resource) => resource.englishStatus === "official").length}</strong>
            <span>{copy.officialEnglish}</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <div id="search">
    <SearchPanel lang={lang} resources={typedResources} showAuthorityFilter />
  </div>

  <section class="section">
    <div class="section-header">
      <div>
        <h2>{copy.latest}</h2>
        <p class="section-lead">{lang === "zh" ? "近期入库的法律、政策和实践资料。" : "Recently added legal, policy, and practice records."}</p>
      </div>
      <a class="hero-link" href={languagePath(lang, "/resources/")}>{copy.navResources}</a>
    </div>
    <div class="resource-grid">
      {latest.map((resource) => <ResourceCard resource={resource} lang={lang} />)}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>{copy.categories}</h2>
    </div>
    <div class="taxonomy-grid">
      {libraryCategories.map((category) => (
        <article class="taxonomy-card">
          <h3>{category.label[lang]}</h3>
          <p>{category.description[lang]}</p>
          <a href={languagePath(lang, `/categories/${category.id}/`)}>{lang === "zh" ? "查看栏目" : "View category"}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>{copy.topics}</h2>
    </div>
    <CoverageBoard lang={lang} />
    <div class="taxonomy-grid">
      {topics.map((topic) => (
        <article class="taxonomy-card">
          <h3>{topic.label[lang]}</h3>
          <p>{topic.description[lang]}</p>
          <a href={languagePath(lang, `/topics/${topic.id}/`)}>{lang === "zh" ? "进入专题" : "Open topic"}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>{copy.tools}</h2>
    </div>
    <div class="tool-grid">
      {tools.map((tool) => (
        <article class="tool-card">
          <h3>{tool.label[lang]}</h3>
          <p>{tool.description[lang]}</p>
          <a class="hero-link" href={languagePath(lang, `/tools/${tool.id}/`)}>{lang === "zh" ? "打开" : "Open"}</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
