---
import SearchPanel from "../../../components/SearchPanel.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  categories,
  getCategory,
  getCopy,
  typedResources,
  type Language
} from "../../../lib/content";

export function getStaticPaths() {
  return ["zh", "en"].flatMap((lang) =>
    categories.map((category) => ({ params: { lang, category: category.id } }))
  );
}

const lang = Astro.params.lang as Language;
const categoryId = Astro.params.category as string;
const copy = getCopy(lang);
const category = getCategory(categoryId);
const resources = typedResources.filter((resource) => resource.category === categoryId);
---

<BaseLayout lang={lang} title={category.label[lang]} active="resources" alternatePath={`/categories/${categoryId}/`}>
  <section class="page-band">
    <div class="page-band-inner">
      <p class="eyebrow">{copy.categories}</p>
      <h1>{category.label[lang]}</h1>
      <p class="section-lead">{category.description[lang]}</p>
    </div>
  </section>
<section class="section">
    <SearchPanel lang={lang} resources={resources} compact showAuthorityFilter />
  </section>
</BaseLayout>
