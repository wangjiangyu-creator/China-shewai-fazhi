---
import { categories, getCopy, languagePath, type Language } from "../lib/content";

interface Props {
  lang: Language;
  title?: string;
  description?: string;
  active?: "home" | "resources" | "scholarship" | "topics" | "tools";
  alternatePath?: string;
}

const { lang, title, description, active = "home", alternatePath = "/" } = Astro.props;
const copy = getCopy(lang);
const pageTitle = title ? `${title} | ${copy.shortName}` : copy.siteName;
const pageDescription = description ?? copy.intro;
const otherLang = lang === "zh" ? "en" : "zh";
const switchUrl = languagePath(otherLang, alternatePath);
---

<!doctype html>
<html lang={lang === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={languagePath(lang)}>
        <span class="brand-mark">FR</span>
        <span>
          <strong>{copy.shortName}</strong>
          <small>{copy.eyebrow}</small>
        </span>
      </a>
      <nav class="main-nav" aria-label="Primary navigation">
        <a class:list={{ active: active === "home" }} href={languagePath(lang)}>{copy.navHome}</a>
        <a class:list={{ active: active === "resources" }} href={languagePath(lang, "/resources/")}>{copy.navResources}</a>
        <a class:list={{ active: active === "scholarship" }} href={languagePath(lang, "/scholarship/")}>{copy.navScholarship}</a>
        <a class:list={{ active: active === "topics" }} href={languagePath(lang, "/topics/")}>{copy.navTopics}</a>
        <a class:list={{ active: active === "tools" }} href={languagePath(lang, "/tools/")}>{copy.navTools}</a>
      </nav>
      <a class="language-link" href={switchUrl}>{copy.languageSwitch}</a>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div>
        <strong>{copy.siteName}</strong>
        <p>{copy.intro}</p>
      </div>
      <div class="footer-links">
        {categories.map((category) => (
          <a href={languagePath(lang, `/categories/${category.id}/`)}>{category.label[lang]}</a>
        ))}
      </div>
    </footer>
  </body>
</html>
